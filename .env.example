# Frontend (Vite — prefixed with VITE_)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# API routes (Vercel serverless — no prefix needed)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here
R2_ACCOUNT_ID=your-cloudflare-account-id
R2_ACCESS_KEY_ID=your-r2-access-key
R2_SECRET_ACCESS_KEY=your-r2-secret-key
R2_BUCKET_NAME=cardigan-documents

# Push notifications (generate with: node scripts/generate-vapid-keys.mjs)
# The VAPID public key must be exposed to both the client bundle (Vite
# requires the VITE_ prefix) and the server (no prefix). Set both to the
# same value on Vercel.
VITE_VAPID_PUBLIC_KEY=your-vapid-public-key
VAPID_PUBLIC_KEY=your-vapid-public-key
VAPID_PRIVATE_KEY=your-vapid-private-key
VAPID_SUBJECT=mailto:your-email@example.com
CRON_SECRET=your-cron-secret-here

# Notes encryption — server-held recovery key (RSA-OAEP-2048).
# Generate with: node scripts/generate-notes-recovery-keypair.mjs
# Public key is bundled into the client; private key stays server-only
# and is read solely by api/admin-recover-encryption.js.
VITE_NOTES_RECOVERY_PUBLIC_KEY=
NOTES_RECOVERY_PRIVATE_KEY=

# Observability (Sentry). Leave unset in dev — the client init + serverless
# wrapper both no-op without a DSN, so errors stay in the browser/Vercel
# console. Use separate DSNs for client and server so they can be routed
# and rotated independently.
VITE_SENTRY_DSN=
SENTRY_DSN=
