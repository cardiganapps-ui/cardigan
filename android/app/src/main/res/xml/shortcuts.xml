<?xml version="1.0" encoding="utf-8"?>
<!--
  Android home-screen long-press shortcuts. These appear when the user
  long-presses the Cardigan app icon on the home screen / launcher.

  Each shortcut launches MainActivity with a deep-link URI; the URI's
  query string is forwarded to the embedded webview, where App.jsx's
  shortcut-receiver effect (see "PWA / native app shortcuts receiver"
  comment) drains the fab=/screen= params and fires the matching
  action.

  Icons live in res/drawable/shortcut_*.xml as vector drawables —
  one per shortcut so the long-press menu doesn't read as three
  copies of the same app icon. Each drawable mirrors the
  public/shortcut-*.svg used by the PWA manifest so launcher
  surfaces stay visually consistent across install paths.

  Keep in sync with the `shortcuts` array in public/manifest.json so
  the PWA + native install surfaces present the same three actions.
-->
<shortcuts xmlns:android="http://schemas.android.com/apk/res/android">

    <shortcut
        android:shortcutId="new_patient"
        android:enabled="true"
        android:icon="@drawable/shortcut_patient"
        android:shortcutShortLabel="@string/shortcut_new_patient_short"
        android:shortcutLongLabel="@string/shortcut_new_patient_long">
        <intent
            android:action="android.intent.action.VIEW"
            android:targetPackage="mx.cardigan.app"
            android:targetClass="mx.cardigan.app.MainActivity"
            android:data="https://cardigan.mx/?fab=patient" />
        <categories android:name="android.shortcut.conversation" />
    </shortcut>

    <shortcut
        android:shortcutId="today"
        android:enabled="true"
        android:icon="@drawable/shortcut_today"
        android:shortcutShortLabel="@string/shortcut_today_short"
        android:shortcutLongLabel="@string/shortcut_today_long">
        <intent
            android:action="android.intent.action.VIEW"
            android:targetPackage="mx.cardigan.app"
            android:targetClass="mx.cardigan.app.MainActivity"
            android:data="https://cardigan.mx/?screen=agenda" />
        <categories android:name="android.shortcut.conversation" />
    </shortcut>

    <shortcut
        android:shortcutId="record_payment"
        android:enabled="true"
        android:icon="@drawable/shortcut_payment"
        android:shortcutShortLabel="@string/shortcut_payment_short"
        android:shortcutLongLabel="@string/shortcut_payment_long">
        <intent
            android:action="android.intent.action.VIEW"
            android:targetPackage="mx.cardigan.app"
            android:targetClass="mx.cardigan.app.MainActivity"
            android:data="https://cardigan.mx/?fab=payment" />
        <categories android:name="android.shortcut.conversation" />
    </shortcut>

</shortcuts>
