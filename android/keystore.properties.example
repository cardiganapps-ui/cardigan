# Release signing config — copy to keystore.properties (gitignored) on
# the build machine and fill in the real values. The actual file MUST
# NOT be committed; android/.gitignore covers both this filename and
# *.jks / *.keystore artifacts.
#
# storeFile is resolved relative to the android/ directory.
#
# Generate the upload keystore once (one-time, persist forever):
#   keytool -genkeypair -v \
#     -keystore android/cardigan-upload.keystore \
#     -keyalg RSA -keysize 2048 -validity 36500 \
#     -alias cardigan-upload \
#     -dname "CN=Cardigan, OU=Apps, O=Cardigan, L=Ciudad de Mexico, ST=CDMX, C=MX"
#
# Then build a signed AAB:
#   npm run cap:bundle:android
#   # → android/app/build/outputs/bundle/release/app-release.aab

storeFile=cardigan-upload.keystore
storePassword=<your-store-password>
keyAlias=cardigan-upload
keyPassword=<your-key-password>
