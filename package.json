{
  "name": "cardigan",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "prebuild": "node scripts/audit-api-auth.mjs && npm run audit:deps",
    "build": "vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:hooks": "vitest run src/hooks/__tests__",
    "bugs": "node --env-file=.env.local scripts/bugs.js",
    "audit:api": "node scripts/audit-api-auth.mjs",
    "audit:deps": "npm audit --omit=dev --audit-level=critical",
    "audit:db": "node --env-file=.env.local scripts/audit-db-health.mjs",
    "audit:orphans": "node --env-file=.env.local scripts/audit-orphan-rows.mjs",
    "audit:signup": "node --env-file=.env.local scripts/verify-signup-flow.mjs",
    "cap:sync": "npm run build && npx cap sync android",
    "cap:open:android": "npx cap open android",
    "cap:run:android": "npm run build && npx cap run android"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.92.0",
    "@aws-sdk/client-s3": "^3.1028.0",
    "@aws-sdk/s3-request-presigner": "^3.1028.0",
    "@capacitor/android": "^8.3.3",
    "@capacitor/app": "^8.1.0",
    "@capacitor/browser": "^8.0.3",
    "@capacitor/core": "^8.3.3",
    "@capacitor/haptics": "^8.0.2",
    "@capacitor/push-notifications": "^8.0.4",
    "@capacitor/share": "^8.0.1",
    "@capacitor/splash-screen": "^8.0.1",
    "@capacitor/status-bar": "^8.0.2",
    "@sentry/node": "^10.50.0",
    "@sentry/react": "^10.50.0",
    "@supabase/supabase-js": "^2.102.1",
    "@vercel/analytics": "^2.0.1",
    "@vercel/edge-config": "^1.4.3",
    "@vercel/speed-insights": "^2.0.0",
    "heic2any": "^0.0.4",
    "jspdf": "^4.2.1",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "read-excel-file": "^9.0.9",
    "web-push": "^3.6.7"
  },
  "devDependencies": {
    "@capacitor/cli": "^8.3.3",
    "@eslint/js": "^9.39.4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^4.7.0",
    "eslint": "^9.39.4",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "happy-dom": "^20.9.0",
    "vite": "5.4.19",
    "vite-plugin-pwa": "^1.2.0",
    "vitest": "^4.1.4"
  }
}
