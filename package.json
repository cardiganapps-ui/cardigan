{
  "name": "cardigan",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "prepare": "husky",
    "prebuild": "node scripts/audit-api-auth.mjs && npm run audit:deps && node --experimental-strip-types scripts/gen-privacy-page.mjs",
    "build": "rm -rf node_modules/.vite dist && vite build",
    "lint": "eslint .",
    "size": "size-limit",
    "typecheck": "tsc --noEmit && tsc -p src/sw-tsconfig.json && tsc -p api/tsconfig.json",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:parity": "vitest run src/utils/__tests__/accounting.parity.test.ts",
    "test:coverage": "vitest run --coverage",
    "test:hooks": "vitest run src/hooks/__tests__",
    "test:e2e": "playwright test",
    "test:e2e:staging": "playwright test --config playwright.staging.config.js",
    "build:e2e": "vite build --mode e2e",
    "build:e2e-staging": "vite build --mode e2e-staging",
    "e2e:staging:seed": "node --env-file=.env.staging.local scripts/seed-e2e-staging.mjs",
    "e2e:staging:verify": "node --env-file=.env.staging.local scripts/verify-e2e-staging-money.mjs",
    "bugs": "node --env-file=.env.local scripts/bugs.js",
    "audit:api": "node scripts/audit-api-auth.mjs",
    "audit:deps": "npm audit --omit=dev --audit-level=critical",
    "audit:db": "node --env-file=.env.local scripts/audit-db-health.mjs",
    "audit:orphans": "node --env-file=.env.local scripts/audit-orphan-rows.mjs",
    "audit:signup": "node --env-file=.env.local scripts/verify-signup-flow.mjs",
    "audit:i18n": "node scripts/audit-i18n.mjs",
    "demo:seed": "node --env-file=.env.local scripts/seed-reviewer-demo.mjs",
    "cap:sync": "npm run build && npx cap sync android",
    "cap:open:android": "npx cap open android",
    "cap:run:android": "npm run build && npx cap run android",
    "cap:bundle:android": "npm run build && npx cap sync android && cd android && ./gradlew :app:bundleRelease && echo '\\nAAB → android/app/build/outputs/bundle/release/app-release.aab'",
    "cap:fingerprint:android": "keytool -list -v -keystore android/cardigan-upload.keystore -alias cardigan-upload 2>/dev/null | grep 'SHA256:' || echo 'No keystore at android/cardigan-upload.keystore — run scripts/android-keystore.sh first'",
    "gen:types": "node --env-file=.env.local scripts/gen-types.mjs"
  },
  "lint-staged": {
    "*.{js,jsx,mjs,ts,tsx}": [
      "eslint --fix",
      "vitest related --run --passWithNoTests"
    ]
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.92.0",
    "@aws-sdk/client-s3": "^3.1075.0",
    "@aws-sdk/s3-request-presigner": "^3.1075.0",
    "@capacitor/android": "^8.3.3",
    "@capacitor/app": "^8.1.0",
    "@capacitor/app-launcher": "^8.0.1",
    "@capacitor/browser": "^8.0.3",
    "@capacitor/camera": "^8.2.0",
    "@capacitor/core": "^8.3.3",
    "@capacitor/haptics": "^8.0.2",
    "@capacitor/ios": "^8.4.0",
    "@capacitor/push-notifications": "^8.0.4",
    "@capacitor/share": "^8.0.1",
    "@capacitor/splash-screen": "^8.0.1",
    "@capacitor/status-bar": "^8.0.2",
    "@capawesome/capacitor-apple-sign-in": "^0.1.0",
    "@capgo/capacitor-passkey": "^8.3.8",
    "@capgo/capacitor-social-login": "^8.3.27",
    "@sentry/node": "^10.50.0",
    "@sentry/react": "^10.50.0",
    "@supabase/supabase-js": "^2.108.2",
    "@vercel/analytics": "^2.0.1",
    "@vercel/edge-config": "^1.4.3",
    "@vercel/speed-insights": "^2.0.0",
    "firebase-admin": "^13.9.0",
    "heic2any": "^0.0.4",
    "jspdf": "^4.2.1",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "read-excel-file": "^9.0.9",
    "web-push": "^3.6.7"
  },
  "devDependencies": {
    "@capacitor/assets": "^3.0.5",
    "@capacitor/cli": "^8.3.3",
    "@eslint/js": "^9.39.4",
    "@playwright/test": "^1.60.0",
    "@sentry/vite-plugin": "^5.3.0",
    "@size-limit/file": "^12.1.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^20.19.43",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^4.7.0",
    "@vitest/coverage-v8": "^4.1.9",
    "eslint": "^9.39.4",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "happy-dom": "^20.9.0",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.7",
    "sharp": "^0.34.5",
    "size-limit": "^12.1.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.61.1",
    "vite": "5.4.19",
    "vite-plugin-pwa": "^1.2.0",
    "vitest": "^4.1.4"
  }
}
