{
  // ── TypeScript config for the Vercel serverless functions (api/) ──
  // Separate from the root tsconfig because api/ runs on Node, not the
  // browser: it needs the Node lib/types (process, Buffer, node:crypto)
  // and — crucially — NodeNext module resolution. api/ is ESM with
  // explicit ".js" import specifiers (required by Node ESM at runtime);
  // NodeNext is the resolution mode that maps an `import "./_foo.js"`
  // onto the `_foo.ts` source during the migration, exactly as Vercel's
  // @vercel/node builder does when it compiles these functions. The root
  // tsconfig's `bundler` resolution can't do that, which is why this is
  // its own project. Type-checking only (noEmit) — Vercel owns the build.
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022"],
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "strict": true,
    "allowJs": false,
    "noEmit": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "forceConsistentCasingInFileNames": true,
    "moduleDetection": "force",
    "types": ["node"]
  },
  "include": ["**/*.ts"]
}
