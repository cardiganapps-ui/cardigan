# Test-mode env for vitest (vite loads .env.test in mode "test").
#
# Unit tests never make real network calls — components that import
# src/supabaseClient.ts only need createClient() to construct without
# throwing "supabaseUrl is required". These are syntactically-valid but
# obviously-fake values (mirroring .env.e2e), committed so the suite is
# self-contained and doesn't depend on a developer's local .env.local.
# Tests that exercise Supabase behaviour mock ../supabaseClient explicitly.
VITE_SUPABASE_URL=https://test.example.invalid
VITE_SUPABASE_ANON_KEY=test-fake-anon-key
